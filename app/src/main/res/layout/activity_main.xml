<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/root_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <!-- Action buttons: top, below status bar -->
    <LinearLayout
        android:id="@+id/top_toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="end"
        android:padding="12dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent">

        <ImageView
            android:id="@+id/camera_switch"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:padding="8dp"
            android:contentDescription="@string/switch_camera_desc"
            android:src="@drawable/ic_camera_switch"
            android:background="@drawable/bg_circle_button"
            android:layout_marginEnd="8dp"/>

        <ImageView
            android:id="@+id/screenshot"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:padding="8dp"
            android:contentDescription="@string/screenshot_desc"
            android:src="@drawable/ic_screenshot"
            android:background="@drawable/bg_circle_button"
            android:layout_marginEnd="8dp"/>

        <ImageView
            android:id="@+id/gallery"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:padding="8dp"
            android:contentDescription="@string/gallery_desc"
            android:src="@drawable/ic_gallery"
            android:background="@drawable/bg_circle_button"
            android:layout_marginEnd="8dp"/>

        <ImageView
            android:id="@+id/rotate_button"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:padding="8dp"
            android:contentDescription="@string/rotate_desc"
            android:src="@drawable/ic_rotate"
            android:background="@drawable/bg_circle_button"
            android:layout_marginEnd="8dp"/>

        <ImageView
            android:id="@+id/filter_button"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:padding="8dp"
            android:contentDescription="@string/filter_desc"
            android:src="@drawable/ic_filter"
            android:background="@drawable/bg_circle_button"/>

    </LinearLayout>

    <!-- Camera preview: fills space between top_toolbar and timing_text -->
    <androidx.camera.view.PreviewView
        android:id="@+id/camera_preview_match"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/top_toolbar"
        app:layout_constraintBottom_toTopOf="@id/timing_text"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"/>

    <!-- Detection overlay: exactly matches PreviewView bounds -->
    <com.crowdhuman.detector.analysis.DetectionOverlayView
        android:id="@+id/box_label_canvas"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:contentDescription="@string/detection_overlay_desc"
        android:clickable="false"
        android:focusable="false"
        app:layout_constraintTop_toTopOf="@id/camera_preview_match"
        app:layout_constraintBottom_toBottomOf="@id/camera_preview_match"
        app:layout_constraintLeft_toLeftOf="@id/camera_preview_match"
        app:layout_constraintRight_toRightOf="@id/camera_preview_match"/>

    <!-- Loading indicator -->
    <com.google.android.material.progressindicator.CircularProgressIndicator
        android:id="@+id/loading_indicator"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:indeterminate="true"
        android:visibility="gone"
        app:indicatorColor="@color/white"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"/>

    <!-- Error panel -->
    <LinearLayout
        android:id="@+id/error_panel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="24dp"
        android:background="@color/error_panel_bg"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent">

        <TextView
            android:id="@+id/error_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:gravity="center"
            android:layout_marginBottom="16dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/retry_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/retry"
            app:cornerRadius="8dp"/>
    </LinearLayout>

    <!-- Per-stage timing breakdown: above bottom control panel -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/timing_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/control_panel_bg"
        app:layout_constraintBottom_toTopOf="@id/layout2"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent">

        <TextView
            android:id="@+id/timing_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textColor="@color/white"
            android:textSize="10sp"
            android:padding="6dp"
            android:shadowColor="@color/black"
            android:shadowRadius="2"
            android:shadowDx="1"
            android:shadowDy="1"
            android:lineSpacingMultiplier="1.1"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toLeftOf="@id/timing_toggle"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/timing_toggle"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:layout_marginEnd="4dp"
            android:minWidth="48dp"
            android:text="Detail"
            android:textColor="@color/white"
            android:textSize="10sp"
            android:paddingHorizontal="8dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            app:cornerRadius="4dp"
            app:backgroundTint="#444444"/>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Bottom control panel -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layout2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/control_panel_bg"
        android:padding="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent">

        <!-- Threshold row -->
        <TextView
            android:id="@+id/threshold_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintLeft_toLeftOf="parent"
            android:layout_marginStart="8dp"
            android:textColor="@color/white"
            android:text="@string/threshold_label" />

        <TextView
            android:id="@+id/threshold_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            android:layout_marginEnd="8dp"
            android:textColor="@color/white"
            android:text="@string/default_threshold" />

        <SeekBar
            android:id="@+id/threshold_seekbar"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:max="100"
            android:progress="25"
            app:layout_constraintTop_toBottomOf="@id/threshold_label"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/detect_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toBottomOf="@id/threshold_seekbar"
            app:layout_constraintLeft_toLeftOf="parent"
            android:layout_marginStart="8dp"
            android:layout_marginTop="4dp"
            android:textColor="@color/white"
            android:text="@string/detect_count_label" />

        <TextView
            android:id="@+id/detect_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toBottomOf="@id/threshold_seekbar"
            app:layout_constraintRight_toRightOf="parent"
            android:layout_marginEnd="8dp"
            android:layout_marginTop="4dp"
            android:text="@string/default_zero"
            android:textColor="@color/white" />

        <TextView
            android:id="@+id/inference"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toBottomOf="@id/detect_name"
            app:layout_constraintLeft_toLeftOf="parent"
            android:layout_marginStart="8dp"
            android:layout_marginTop="4dp"
            android:textColor="@color/white"
            android:text="@string/inference_time_label" />

        <TextView
            android:id="@+id/inference_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toBottomOf="@id/detect_count"
            app:layout_constraintRight_toRightOf="parent"
            android:layout_marginEnd="8dp"
            android:layout_marginTop="4dp"
            android:text="@string/default_ms"
            android:textColor="@color/white" />

        <TextView
            android:id="@+id/frame"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toBottomOf="@id/inference"
            app:layout_constraintLeft_toLeftOf="parent"
            android:layout_marginStart="8dp"
            android:layout_marginTop="4dp"
            android:textColor="@color/white"
            android:text="@string/frame_size_label" />

        <TextView
            android:id="@+id/frame_size"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toBottomOf="@id/inference_time"
            app:layout_constraintRight_toRightOf="parent"
            android:layout_marginEnd="8dp"
            android:layout_marginTop="4dp"
            android:text="@string/default_frame_size"
            android:textColor="@color/white" />

        <TextView
            android:id="@+id/model_name"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:gravity="center_vertical"
            app:layout_constraintTop_toBottomOf="@id/frame"
            app:layout_constraintLeft_toLeftOf="parent"
            android:layout_marginStart="8dp"
            android:layout_marginTop="4dp"
            android:textColor="@color/white"
            android:labelFor="@+id/model"
            android:text="@string/model_label" />

        <Spinner
            android:id="@+id/model"
            android:layout_width="wrap_content"
            android:layout_height="48dp"
            android:minHeight="48dp"
            app:layout_constraintTop_toBottomOf="@id/frame_size"
            app:layout_constraintRight_toRightOf="parent"
            android:background="#00000000"
            android:entries="@array/model"
            android:padding="0dp"
            android:gravity="end"
            android:layout_marginEnd="8dp"
            android:layout_marginTop="4dp"
            android:contentDescription="@string/model_label" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
